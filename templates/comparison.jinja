<!doctype html>
<html lang="en-UK">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} | Compare Languages</title>
    <meta name="author" content="Cosmo Grant" />
  </head>

  <body>
    <main>
      <h1><a href="index.html" aria-label="Back"><svg width="0.6em" height="0.6em" viewBox="0 0 16 16" fill="currentColor"><path d="M16 7H3.8l5.6-5.6L8 0 0 8l8 8 1.4-1.4L3.8 9H16z"/></svg></a> {{ title }}</h1>

      <div id="tab-buttons">
      {% for snippet in snippets %}
        <button>{{ snippet.title }}</button>
      {% endfor %}
      </div>

      <div id="snippet-container">
        {% for snippet in snippets %}
        <div>
          <pre><code class="lang-{{ snippet.language }}">{{ snippet.code }}</code></pre>
          <div class="output-section">
            <button class="output-toggle">output</button>
            <pre><samp>{{ snippet.output }}</samp></pre>
          </div>
        </div>
        {% endfor %}
      </div>

      <div id="discussion">
        {{ discussion }}
      </div>
    </main>

    <link rel="stylesheet" href="style.css" />
    <link rel="stylesheet" href="hljs-theme.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="comparison.js"></script>
  </body>
</html>
